{
    "name": "openemr/oe-module-institutional",
    "description": "Institutional workflows — Emergency Department, Observation Stay, Behavioral Health, and Assisted Living — for OpenEMR.",
    "type": "openemr-module",
    "license": "GPL-3.0-or-later",
    "homepage": "https://github.com/sjpadgett/oe-module-institutional",
    "authors": [
        {
            "name": "Jerry Padgett",
            "email": "sjpadgett@gmail.com",
            "homepage": "https://www.opensourcedemr.com",
            "role": "Developer"
        }
    ],
    "keywords": [
        "openemr",
        "module",
        "emergency-department",
        "assisted-living",
        "behavioral-health",
        "observation",
        "inpatient",
        "home-based-care",
        "emar",
        "healthcare",
        "ehr"
    ],
    "support": {
        "issues": "https://github.com/sjpadgett/oe-module-institutional/issues",
        "source": "https://github.com/sjpadgett/oe-module-institutional"
    },
    "require": {
        "php": ">=8.2",
        "twbs/bootstrap": "^5.3"
    },
    "autoload": {
        "psr-4": {
            "OpenEMR\\Modules\\Institutional\\": "src/"
        }
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.2"
        },
        "optimize-autoloader": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
